# Copy to .env.local for local development.

# Points the browser at the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Reserved for any future direct-to-S3 asset URLs. Not required today — every
# file the app links to already goes through a backend-issued signed URL (see
# FileService.get_signed_url), by design, so the browser never needs to know
# the bucket name to fetch a file.
NEXT_PUBLIC_S3_BUCKET=
NEXT_PUBLIC_REGION=us-east-1

# development | staging | production — purely informational (e.g. for a
# future "you're on staging" banner); does not change API behavior.
NEXT_PUBLIC_ENVIRONMENT=development
