# Copy this file to .env (local dev) or use it as a reference for every
# environment variable the application reads. Never commit real secrets —
# in staging/production these come from AWS Secrets Manager, not this file.

ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
# text | json  (use json in staging/production for CloudWatch Logs Insights)
LOG_FORMAT=text

# --- Datastores ---
# Local Postgres for development; Amazon RDS in staging/production.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/commerceos_db
# Local Redis for development; Amazon ElastiCache in staging/production.
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
SECRET_KEY=change-me-to-a-random-64-char-value
# Optional: a distinct signing key for JWTs. Falls back to SECRET_KEY when
# unset, so this only needs to be set if you want a separate key rotation
# schedule for auth tokens vs. everything else that uses SECRET_KEY.
JWT_SECRET=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- URLs / CORS ---
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
# Comma-separated extra origins allowed to call the API, beyond FRONTEND_URL/APP_URL.
CORS_ORIGINS=

# --- Email ---
MAIL_FROM=CommerceOS <no-reply@commerceos.local>
# smtp | ses — smtp is a development-only fallback; use ses everywhere else.
EMAIL_PROVIDER=smtp
# Optional overrides for the SES send path; both fall back to AWS_REGION /
# MAIL_FROM when left empty.
SES_REGION=
SES_FROM_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- File storage ---
# local | s3  (use s3 in staging/production)
STORAGE_PROVIDER=local
S3_BUCKET=commerceos
# Optional: only for S3-compatible test endpoints (e.g. LocalStack). Leave
# empty to talk to real AWS S3.
S3_ENDPOINT=
S3_REGION=us-east-1
FILE_UPLOAD_MAX_BYTES=20971520
VIRUS_SCAN_COMMAND=
IMAGE_OPTIMIZATION_ENABLED=True
IMAGE_OPTIMIZATION_QUALITY=85

# --- AWS ---
AWS_REGION=us-east-1
# Leave these empty on EC2 — boto3 uses the instance's IAM role automatically.
# Only set them for local development against a real AWS account, or when
# running under temporary STS credentials (AWS_SESSION_TOKEN).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
# When true, secrets are pulled from AWS Secrets Manager at process startup
# (secret name = f"{AWS_SECRETS_MANAGER_PREFIX}/app") and OVERRIDE whatever is
# already in the environment — Secrets Manager is always the source of truth
# when enabled, not just a fallback for unset values.
USE_AWS_SECRETS_MANAGER=False
AWS_SECRETS_MANAGER_PREFIX=

# --- Security ---
# Redirect http:// to https:// based on X-Forwarded-Proto (set by the ALB/nginx).
# Leave False if TLS termination already guarantees HTTPS-only traffic reaches the app.
FORCE_HTTPS=False
