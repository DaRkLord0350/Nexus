{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "CommerceOSCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents",
        "logs:DescribeLogStreams"
      ],
      "Resource": "arn:aws:logs:us-east-1:ACCOUNT_ID:log-group:/commerceos/*"
    }
  ]
}
