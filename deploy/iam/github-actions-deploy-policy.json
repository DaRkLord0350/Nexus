{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TriggerDeployViaSSM",
      "Effect": "Allow",
      "Action": [
        "ssm:SendCommand"
      ],
      "Resource": [
        "arn:aws:ssm:us-east-1::document/AWS-RunShellScript",
        "arn:aws:ec2:us-east-1:ACCOUNT_ID:instance/*"
      ],
      "Condition": {
        "StringEquals": {
          "ssm:resourceTag/App": "commerceos"
        }
      }
    },
    {
      "Sid": "ReadDeployStatus",
      "Effect": "Allow",
      "Action": [
        "ssm:GetCommandInvocation",
        "ssm:ListCommandInvocations"
      ],
      "Resource": "*"
    }
  ]
}
